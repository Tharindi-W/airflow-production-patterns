# Local environment for the no-Docker (native WSL) setup.
# Copy this file to .env and adjust only if you need to.
#
#   cp .env.example .env
#
# These are LOCAL DEVELOPMENT credentials for a Postgres instance that listens
# on localhost inside WSL only. They are not secrets and are safe to commit as
# an example. Do not reuse them anywhere real.

# --- Postgres connection (local, inside WSL) ---
PGHOST=localhost
PGPORT=5432

# Airflow metadata database
AIRFLOW_DB=airflow_meta
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# Mock warehouse database (the "data warehouse" the patterns load into)
WAREHOUSE_DB=warehouse
WAREHOUSE_USER=warehouse
WAREHOUSE_PASSWORD=warehouse

# --- Airflow runtime locations ---
# Kept in the WSL home directory on purpose. The repo lives on the Windows
# mount (/mnt/c/...), which is slow for the venv and for Airflow logs, so we
# keep those off the mount.
AIRFLOW_HOME=$HOME/.airflow-patterns
AIRFLOW_VENV=$HOME/.venvs/airflow-patterns

# Default Airflow web UI admin login created by scripts/setup_airflow.sh
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
